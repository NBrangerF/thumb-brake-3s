{"card_id":"PURE_HOOK_001","hook_scope":"product_independent","pattern_name":"强刺激钩子：反常静物","hook_type":"H1","sub_type":"visual_contrast","product_relation_type":"pure_decoy_observation","narrative_function":"pattern_interrupt","one_sentence_logic":"用一个明显不合常理但安全的静物关系制造停滑，随后可以在结尾用商品或结果线索回收注意力。","applicable_categories":["general"],"category_fit_weight":{"general":0.88},"audience_fit":["conversion_viewers"],"selling_point_fit":["visible_result","speed","trust"],"emotional_path":"curiosity_to_reveal","stimulation_level":"S2","time_structure":{"0_1s":"反常静物关系先停滑。","1_3s":"解释这个反常关系对应的用户痛点或结果缺口。","3_5s":"商品进入画面，给出可验证承接。"},"visual_criteria":["画面必须安全、无真实危险行为。","只保留一个异常关系，不做复杂剧情。","商品线索可以在结尾短暂出现，但必须可回收。"],"motion_criteria":["动作只用于揭示反常关系。"],"audio_criteria":["短促提示音即可，不制造恐吓。"],"text_criteria":["最多一条短句，且不渲染进首帧图。"],"product_bridge_rule":"纯钩子只能作为停滑入口，前半段优先停滑，结尾用商品相关痛点、证据或结果回收。","reference_requirements":["first_frame_reference","product_reference"],"recommended_generation_mode":"first_frame","model_feasibility":"high","prompt_slots":{"stimulus":"反常静物","recovery":"商品痛点回收","product_name":"product name"},"sample_concept_templates":["先给出一个安全反常画面，再用{product_name}解释原因。"],"source_observations":["Distilled from local deep research on safe high-salience but fast-recovered hooks."],"source_metadata":{"research_basis":["deep-research-report-2","deep-research-report-3"],"storage_policy":"Distilled reusable grammar only."},"update_history":[{"date":"2026-05-14","change":"Added product-independent hook scope."}],"status":"active"}
{"card_id":"PURE_HOOK_002","hook_scope":"product_independent","pattern_name":"强刺激钩子：未完成动作","hook_type":"H3","sub_type":"unfinished_action","product_relation_type":"pure_decoy_observation","narrative_function":"open_loop","one_sentence_logic":"把一个即将发生但尚未完成的动作停在临界瞬间，制造继续看的冲动，再用商品或结果线索回收。","applicable_categories":["general"],"category_fit_weight":{"general":0.9},"audience_fit":["conversion_viewers"],"selling_point_fit":["speed","ease_of_use","visible_result"],"emotional_path":"tension_to_relief","stimulation_level":"S2","time_structure":{"0_1s":"动作卡在临界点。","1_3s":"露出动作背后的痛点或结果悬念。","3_5s":"商品完成解释或解决。"},"visual_criteria":["动作必须安全、可模仿风险低。","构图集中在手部、表情或物件临界点。"],"motion_criteria":["只保留一个待完成动作。"],"audio_criteria":["可用短暂停顿或轻音效。"],"text_criteria":["不依赖长字幕解释。"],"product_bridge_rule":"动作悬念必须成为商品卖点的铺垫，不允许只做无关悬念。","reference_requirements":["first_frame_reference","video_motion_reference","product_reference"],"recommended_generation_mode":"hybrid","model_feasibility":"high","prompt_slots":{"action":"未完成动作","product_name":"product name"},"sample_concept_templates":["动作停住的一秒，随后{product_name}给出答案。"],"source_observations":["Distilled from first 3-second retention research."],"source_metadata":{"research_basis":["deep-research-report-2","deep-research-report-3"],"storage_policy":"Distilled reusable grammar only."},"update_history":[{"date":"2026-05-14","change":"Added product-independent hook scope."}],"status":"active"}
{"card_id":"PURE_HOOK_003","hook_scope":"product_independent","pattern_name":"强刺激钩子：社交尴尬瞬间","hook_type":"H2","sub_type":"social_embarrassment","product_relation_type":"pure_decoy_observation","narrative_function":"social_friction","one_sentence_logic":"用轻度社交尴尬或被看见的瞬间制造自我代入，再把尴尬原因回收到商品相关问题或结尾答案。","applicable_categories":["general"],"category_fit_weight":{"general":0.86},"audience_fit":["conversion_viewers"],"selling_point_fit":["trust","visible_result"],"emotional_path":"embarrassment_to_confidence","stimulation_level":"S2","time_structure":{"0_1s":"人物表情或旁人反应停滑。","1_3s":"点出尴尬背后的具体问题。","3_5s":"商品作为解决线索出现。"},"visual_criteria":["只做轻度尴尬，不羞辱具体群体。","人物表情要真实，像手机抓拍。"],"motion_criteria":["人物微表情或视线变化即可。"],"audio_criteria":["自然环境声或短促反应声。"],"text_criteria":["可做元数据字幕，不渲染进图。"],"product_bridge_rule":"社交尴尬必须对应商品能解决或证明的问题。","reference_requirements":["first_frame_reference","scene_reference","product_reference"],"recommended_generation_mode":"first_frame","model_feasibility":"high","prompt_slots":{"social_moment":"社交尴尬","product_name":"product name"},"sample_concept_templates":["先让观众代入尴尬，再让{product_name}成为解决理由。"],"source_observations":["Distilled from safe social-signal hook research."],"source_metadata":{"research_basis":["deep-research-report-2","deep-research-report-3"],"storage_policy":"Distilled reusable grammar only."},"update_history":[{"date":"2026-05-14","change":"Added product-independent hook scope."}],"status":"active"}
{"card_id":"PURE_HOOK_004","hook_scope":"product_independent","pattern_name":"强刺激钩子：近距离证据","hook_type":"H5","sub_type":"proof_closeup","product_relation_type":"pure_decoy_observation","narrative_function":"evidence_tease","one_sentence_logic":"先给出一个极近距离的结果证据，让观众想知道发生了什么，再用商品或结果线索回收证据。","applicable_categories":["general"],"category_fit_weight":{"general":0.87},"audience_fit":["conversion_viewers"],"selling_point_fit":["visible_result","trust"],"emotional_path":"shock_to_proof","stimulation_level":"S1","time_structure":{"0_1s":"极近距离证据先出现。","1_3s":"拉开一点点解释证据来自哪个问题。","3_5s":"商品或使用动作进入。"},"visual_criteria":["证据必须可读，不能恶心或血腥。","首帧只展示一个证据点。"],"motion_criteria":["可用轻微推近或拉焦。"],"audio_criteria":["保持克制。"],"text_criteria":["证据靠画面，不靠长文案。"],"product_bridge_rule":"证据要成为商品转化证明的一部分。","reference_requirements":["first_frame_reference","product_reference"],"recommended_generation_mode":"first_frame","model_feasibility":"high","prompt_slots":{"evidence":"证据近景","product_name":"product name"},"sample_concept_templates":["先看到证据，再揭示{product_name}如何制造这个结果。"],"source_observations":["Distilled from conversion proof hook research."],"source_metadata":{"research_basis":["deep-research-report-2"],"storage_policy":"Distilled reusable grammar only."},"update_history":[{"date":"2026-05-14","change":"Added product-independent hook scope."}],"status":"active"}
{"card_id":"PURE_HOOK_005","hook_scope":"product_independent","pattern_name":"强刺激钩子：直视镜头","hook_type":"H6","sub_type":"direct_gaze","product_relation_type":"pure_decoy_observation","narrative_function":"social_signal","one_sentence_logic":"人物突然直视镜头，用强社交线索阻止滑走，再用一句短线索回收到商品问题。","applicable_categories":["general"],"category_fit_weight":{"general":0.85},"audience_fit":["conversion_viewers"],"selling_point_fit":["trust","ease_of_use"],"emotional_path":"curiosity_to_reveal","stimulation_level":"S1","time_structure":{"0_1s":"直视镜头和表情停滑。","1_3s":"人物用动作或口型指向问题。","3_5s":"商品出现并解释。"},"visual_criteria":["直视要真实，不要夸张恐吓。","画面像普通用户自拍或朋友拍摄。"],"motion_criteria":["微表情和轻微靠近镜头。"],"audio_criteria":["适合一句自然口播。"],"text_criteria":["文字只作元数据。"],"product_bridge_rule":"直视镜头必须马上指向商品相关问题或结果。","reference_requirements":["first_frame_reference","scene_reference","product_reference"],"recommended_generation_mode":"hybrid","model_feasibility":"high","prompt_slots":{"gaze":"直视镜头","product_name":"product name"},"sample_concept_templates":["人物突然看向镜头，下一秒把问题交给{product_name}。"],"source_observations":["Distilled from gaze-cue and social-signal hook research."],"source_metadata":{"research_basis":["deep-research-report-2"],"storage_policy":"Distilled reusable grammar only."},"update_history":[{"date":"2026-05-14","change":"Added product-independent hook scope."}],"status":"active"}
{"card_id":"PURE_HOOK_006","hook_scope":"product_independent","pattern_name":"强刺激钩子：反常识一句","hook_type":"H3","sub_type":"counterintuitive_claim","product_relation_type":"pure_decoy_observation","narrative_function":"belief_gap","one_sentence_logic":"用一个反常识判断制造认知缺口，但可以先制造认知缺口，再用商品相关解释回收，不做标题党。","applicable_categories":["general"],"category_fit_weight":{"general":0.84},"audience_fit":["conversion_viewers"],"selling_point_fit":["trust","visible_result"],"emotional_path":"curiosity_to_reveal","stimulation_level":"S1","time_structure":{"0_1s":"反常识口播或画面先停滑。","1_3s":"给出商品相关原因。","3_5s":"用商品证据验证。"},"visual_criteria":["首帧用人物/物件表达反常识，不渲染大段文字。"],"motion_criteria":["动作保持简单。"],"audio_criteria":["适合短口播。"],"text_criteria":["字幕只作为 metadata。"],"product_bridge_rule":"反常识最终要能转成商品教育或证据，不允许空喊。","reference_requirements":["first_frame_reference","product_reference"],"recommended_generation_mode":"first_frame","model_feasibility":"high","prompt_slots":{"claim":"反常识判断","product_name":"product name"},"sample_concept_templates":["先打破常识，再用{product_name}给出可见证据。"],"source_observations":["Distilled from low-friction curiosity hook research."],"source_metadata":{"research_basis":["deep-research-report-2"],"storage_policy":"Distilled reusable grammar only."},"update_history":[{"date":"2026-05-14","change":"Added product-independent hook scope."}],"status":"active"}
